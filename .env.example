# MatCreator port configuration
# Copy to .env and customize before deployment

# Core service ports
MATCREATOR_ADK_PORT=8000
MATCREATOR_WEB_PORT=8001
MATCREATOR_FRONTEND_PORT=5173
MATCREATOR_SERVER_PROXY_PORT=80
MATCREATOR_WORKER_BASE_PORT=9001

# Docker host port mappings (set to avoid conflicts)
# MATCREATOR_ADK_HOST_PORT=8000
# MATCREATOR_WEB_HOST_PORT=8001
# MATCREATOR_FRONTEND_HOST_PORT=5173
# MATCREATOR_SERVER_PROXY_HOST_PORT=80

# MCP endpoints
MATCREATOR_MCP_HOST=localhost
MATCREATOR_MCP_DATABASE_PORT=50001
MATCREATOR_MCP_DPA_PORT=50002
MATCREATOR_MCP_ABACUS_PORT=50003
MATCREATOR_MCP_STRUCTURE_PORT=50004
MATCREATOR_MCP_VASP_PORT=50005
MATCREATOR_MCP_MATTERGEN_PORT=50006

# Full URL overrides (optional - override host+port construction)
# MATCREATOR_MCP_DATABASE_URL=http://localhost:51001/sse
# MATCREATOR_MCP_DPA_URL=http://localhost:51002/sse
# MATCREATOR_WEB_TARGET=http://localhost:8001    # full override for the web API URL (used by Vite proxy)
